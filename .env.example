# Shail Configuration File
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: The .env file is gitignored - your API keys will NOT be committed

# ============================================================================
# REQUIRED: Gemini API Key
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This key is required for:
#   - Master Planner (intelligent task routing)
#   - CodeAgent (code generation and execution)
#   - All LLM-powered features
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# OPTIONAL: Gemini Model Configuration
# ============================================================================
# Model to use for Gemini API calls
# Default: gemini-2.0-flash (fast and cost-effective)
# Options: gemini-2.0-flash, gemini-pro, gemini-1.5-pro, etc.
# GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# OPTIONAL: Redis Configuration
# ============================================================================
# Redis connection URL for task queue
# Default: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# OPTIONAL: Database & Storage Paths
# ============================================================================
# Path to SQLite database for conversation memory and task storage
# Default: ./shail_memory.sqlite3 (in project root)
# SHAIL_SQLITE=./shail_memory.sqlite3

# Path to audit log file (JSONL format)
# Default: ./shail_audit.jsonl (in project root)
# SHAIL_AUDIT_LOG=./shail_audit.jsonl

# Workspace root directory (where Shail operates)
# Default: current working directory
# SHAIL_WORKSPACE_ROOT=./workspace

# ============================================================================
# OPTIONAL: Task Queue Configuration
# ============================================================================
# Redis queue name for tasks
# Default: shail_tasks
# SHAIL_TASK_QUEUE=shail_tasks

# ============================================================================
# Auth — Google Sign-In (REQUIRED for "Continue with Google")
# ============================================================================
# Setup:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID → Application type: Web application
#   3. Authorized redirect URI: http://localhost:8000/auth/google/callback
#   4. Copy the Client ID and Client Secret below.
#
# Without these set, Google sign-in will show:
#   "Google OAuth not configured — set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET in .env"
#
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================================================
# Auth — Sign in with Apple (required for "Sign in with Apple")
# ============================================================================
# Set to the bundle identifier of the ShailUI Mac app (the audience claim
# Apple signs into the identity token). Without this the /auth/apple endpoint
# returns 503.
APPLE_AUDIENCE=com.shail.ShailUI

# ============================================================================
# OPTIONAL: Ollama host override
# ============================================================================
# OLLAMA_HOST=http://127.0.0.1:11434

# ============================================================================
# OPTIONAL: LLM-based content scoring for FS captures
# ============================================================================
# Set to 1 to call Ollama for an importance score on each FS-captured file.
# Off by default — heuristic scorer is used instead.
SHAIL_LLM_SCORING=0

# ============================================================================
# Setup Instructions
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your GEMINI_API_KEY
# 3. Save the file
# 4. Restart Shail (worker, API, etc.)
#
# The .env file is automatically loaded when Shail starts.
# No need to manually export environment variables!
